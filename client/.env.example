# Client Environment Variables
# Local dev (recommended): relative path — Vite proxies /api → backend (see vite.config.js)
VITE_API_URL=/api
# Where Vite forwards /api (must match server PORT). If you see ECONNREFUSED, start the API: cd server && npm start
# VITE_PROXY_TARGET=http://127.0.0.1:6000
# Optional: direct backend URL (then set server CORS_ORIGIN to match your app origin)
# VITE_API_URL=http://localhost:6000/api
