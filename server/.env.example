# Server Environment Variables
NODE_ENV=development
PORT=6000

# Database Configuration
MONGO_URI=mongodb://admin:password123@localhost:27017/ai_cost_intelligence?authSource=admin
MONGO_DB=ai_cost_intelligence

# JWT & Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=1d

# Redis Cache
REDIS_URL=redis://localhost:6379

# API Configuration
API_PREFIX=/api
# Comma-separated if you use multiple dev URLs (localhost vs 127.0.0.1)
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Email Service (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@ai-cost-intelligence.com

# Feature Flags
ENABLE_ALERTS=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_JOBS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Google OAuth (Optional)
# To enable "Continue with Google", create OAuth credentials in Google Cloud Console:
# - Authorized JavaScript origins: http://localhost:3000
# - Authorized redirect URI: http://localhost:6000/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:6000/api/auth/google/callback
FRONTEND_URL=http://localhost:3000